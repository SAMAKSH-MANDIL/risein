# Stellar Configuration
# DO NOT commit real secrets — copy this file to .env and fill in values

# Your Stellar secret key (starts with 'S')
STELLAR_SECRET_KEY=

# Your Stellar public key (starts with 'G') — optional, derived from secret
STELLAR_PUBLIC_KEY=

# Stellar network (testnet or public)
STELLAR_NETWORK=testnet

# Stellar Horizon server URL
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Destination address for test transaction
DESTINATION_PUBLIC_KEY=
